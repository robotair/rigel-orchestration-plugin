---
# Example 2: ROS1 Service (Client/Server)
# Demonstrates communication between two ROS1 nodes using services.
#
# Structure:
#   server/ - Service server node (Dockerfile for docker-compose)
#   client/ - Service client node (Dockerfile for docker-compose)
#   Dockerfile  - Combined image for Kubernetes deployment
#   docker-compose.yaml - Local testing with separate containers
#
# Local testing:  docker compose up --build
# Local testing via Rigel Compose plugin: uv run rigel run sequence local_test
# K8s deploy:     uv run rigel run sequence demo

vars:
  distro: "noetic"
  base_image: "rigel-ros1-service:1.0.0"

application:
  distro: "{{ vars.distro }}"

jobs:
  dockerfile:
    plugin: "rigel.plugins.core.ContainerfilePlugin"
    with:
      compiler:
        name: "catkin_make"
      ros_image: "ros:{{ vars.distro }}-ros-core"
      command: "sleep infinity"
      apt:
        - net-tools

  build:
    plugin: "rigel.plugins.core.BuildXPlugin"
    with:
      image: "{{ vars.base_image }}"
      load: true
      push: false

  compose_local:
    plugin: "rigel.plugins.core.ComposePlugin"
    with:
      timeout: 30
      components:
        - name: "server"
          image: "{{ vars.base_image }}"
          command:
            [
              "/bin/bash",
              "-c",
              "source /opt/ros/noetic/setup.bash && python3 /app/server.py",
            ]
        - name: "client"
          image: "{{ vars.base_image }}"
          command:
            [
              "/bin/bash",
              "-c",
              "source /opt/ros/noetic/setup.bash && sleep 3 && python3 /app/client.py",
            ]

  deploy_k8s:
    plugin: "src.plugin.OrchestrationPlugin"
    with:
      orchestration:
        deploy_ros_master: true

        additional_k8s_params:
          ros_master:
            spec:
              template:
                spec:
                  containers:
                    - name: "ros-master-container"
                      image: "ros:noetic-ros-core"
                      command: ["/ros_entrypoint.sh"]
                      args: ["roscore"]

          application:
            spec:
              strategy:
                type: Recreate
              template:
                spec:
                  containers:
                    - name: "ros-app"
                      image: "{{ vars.base_image }}"
                      command: ["/bin/bash", "-c"]
                      args:
                        [
                          "source /opt/ros/noetic/setup.bash && (python3 /app/server.py & sleep 3 && python3 /app/client.py & wait)",
                        ]
                      env:
                        - name: ROS_MASTER_URI
                          value: "http://ros-master:11311"
                        - name: ROS_IP
                          valueFrom:
                            fieldRef:
                              fieldPath: status.podIP

sequences:
  demo:
    stages:
      - jobs: ["build", "deploy_k8s"]

  generated_demo:
    stages:
      - jobs: ["dockerfile", "build", "deploy_k8s"]

  local_test:
    stages:
      - jobs: ["build", "compose_local"]
