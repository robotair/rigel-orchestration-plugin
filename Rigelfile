---
# Rigel Kubernetes Orchestration Plugin - Test Configuration
vars:
  distro: "humble"
  base_image: "nhopf/turtle-rigel:2.0.0-ros2"

application:
  distro: "{{ vars.distro }}"

jobs:
  # NOTE: the following job will overwrite existing Dockerfile on the root of the repository
  containerfile:
    plugin: "rigel.plugins.core.DockerfilePlugin"
    with:
      compiler:
        name: "colcon"
      ros_image: "ros:{{ vars.distro }}"
      command: "ros2 topic pub /hello std_msgs/String 'data: Hello from K8s' --rate 1"
      apt:
        - net-tools
      ignore:
        - examples/
        - app_testing/
      entrypoint:
        - 'PROBE_PATH="$(find /home/rigeluser/ros_workspace/src -maxdepth 3 -name readiness_probe.sh | head -n 1)"'
        - 'if [ -z "$PROBE_PATH" ]; then echo "ERROR: readiness_probe.sh not found in workspace"; exit 1; fi'
        - 'sudo install -m 0755 "$PROBE_PATH" /usr/local/bin/readiness_probe.sh'

  build:
    plugin: "rigel.plugins.core.BuildPlugin"
    with:
      image: "{{ vars.base_image }}"
      load: true
      push: false

  deploy_k8s:
    plugin: "src.plugin.OrchestrationPlugin"
    with:
      orchestration:
        deploy_ros_master: false
        readiness:
          command: "/usr/local/bin/readiness_probe.sh"
        observability:
          enabled: true
        rolling_update:
          strategy: "Rolling"
          max_surge: 1
          max_unavailable: 0
        distributed:
          enabled: false
          default_to_remote: true
          force_local_flag: false
        persistent_storage:
          volumes:
            - name: "logs-volume"
              size: "1Gi"
              storage_class: "standard"
        additional_k8s_params:
          application:
            spec:
              template:
                spec:
                  containers:
                    - name: "ros-app"
                      image: "{{ vars.base_image }}"
                      command:
                        [
                          "/home/rigeluser/robot-entrypoint.sh",
                          "ros2",
                          "topic",
                          "pub",
                          "/hello",
                          "std_msgs/String",
                          "data: Hello from K8s",
                          "--rate",
                          "1",
                        ]
                      readinessProbe:
                        exec:
                          command: ["/usr/local/bin/readiness_probe.sh"]
                        initialDelaySeconds: 10
                        periodSeconds: 5
                      env:
                        - name: CUSTOM_ENV
                          value: "TESTING"
                        - name: APP_VERSION
                          value: "{{ vars.base_image | regex_replace('.*:', '') }}"
                        - name: ROS_DOMAIN_ID
                          value: "0"
                        - name: RMW_IMPLEMENTATION
                          value: "rmw_cyclonedds_cpp"
                      ports:
                        - containerPort: 8080
                      volumeMounts:
                        - name: logs-volume
                          mountPath: /persistent_logs
                  volumes:
                    - name: logs-volume
                      persistentVolumeClaim:
                        claimName: logs-volume-pvc

  update_k8s:
    plugin: "src.plugin.OrchestrationPlugin"
    with:
      orchestration:
        rolling_update:
          strategy: "Rolling"
          max_surge: 1
          max_unavailable: 0
        readiness:
          command: "/usr/local/bin/readiness_probe.sh"

sequences:
  demo:
    stages:
      - jobs: ["build", "deploy_k8s"]
  update:
    stages:
      - jobs: ["build", "update_k8s"]
